<%- include("../../partials/head", { title: "Admin · Messages" }) %>
<%- include("../../partials/nav") %>

<main class="container">
  <div class="row" style="justify-content:space-between; align-items:flex-end">
    <div>
      <h2 style="margin:0">Messages</h2>
      <p class="muted" style="margin:6px 0 0 0">Contact form submissions.</p>
    </div>
    <div class="row">
      <a class="btn" href="/contact">Public contact</a>
    </div>
  </div>

  <div style="margin-top:12px">
    <table class="table">
      <thead>
        <tr>
          <th>From</th>
          <th>Message</th>
          <th>Car</th>
          <th>Received</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (!messages.length) { %>
          <tr><td colspan="5" class="muted">No messages yet.</td></tr>
        <% } %>
        <% messages.forEach((m) => { %>
          <tr>
            <td>
              <strong><%= m.name %></strong>
              <div class="muted"><%= m.email %></div>
              <div class="muted"><%= m.phone || "—" %></div>
            </td>
            <td style="max-width:420px">
              <div style="white-space:pre-wrap"><%= m.message %></div>
            </td>
            <td>
              <% if (m.car_id) { %>
                <a class="pill" href="/cars/<%= m.car_id %>"><%= m.car_title || `Car #${m.car_id}` %></a>
              <% } else { %>
                <span class="muted">—</span>
              <% } %>
            </td>
            <td class="muted"><%= dayjs(m.created_at).format("YYYY-MM-DD HH:mm") %></td>
            <td>
              <form method="post" action="/admin/messages/<%= m.id %>/delete" onsubmit="return confirm('Delete this message?');">
                <button class="btn danger" type="submit">Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</main>

<%- include("../../partials/footer") %>

