<%- include("../partials/head", { title: car.title }) %>
<%- include("../partials/nav") %>

<main class="container">
  <div class="row" style="justify-content:space-between; align-items:flex-end">
    <div>
      <h2 style="margin:0"><%= car.title %></h2>
      <p class="muted" style="margin:6px 0 0 0"><%= car.make %> · <%= car.model %> · <%= car.year %></p>
    </div>
    <div class="row">
      <% if (car.status === "AVAILABLE") { %>
        <span class="badge ok">Available</span>
      <% } else { %>
        <span class="badge warn">Sold</span>
      <% } %>
      <a class="btn" href="/contact">Enquire</a>
    </div>
  </div>

  <% if (images && images.length) { %>
    <section class="card" style="margin-top:14px">
      <div class="row" style="justify-content:space-between; align-items:center">
        <h3 style="margin:0">Photos</h3>
        <a class="btn" href="/contact">Request more details</a>
      </div>
      <div class="grid" style="grid-template-columns: repeat(3, minmax(0, 1fr)); gap:10px; margin-top:10px">
        <% images.forEach((img) => { %>
          <a class="card" style="padding:10px; background:rgba(255,255,255,.03)" href="/uploads/<%= img.filename %>" target="_blank" rel="noreferrer">
            <img src="/uploads/<%= img.filename %>" alt="Car photo" style="width:100%; height:210px; object-fit:cover; border-radius:12px; border:1px solid rgba(255,255,255,.10)" />
          </a>
        <% }) %>
      </div>
    </section>
  <% } %>

  <div class="grid" style="grid-template-columns: 1.2fr .8fr; margin-top:14px">
    <section class="card">
      <h3>Details</h3>
      <div class="row" style="justify-content:space-between; align-items:flex-start; margin-top:10px">
        <div>
          <div class="muted">Price</div>
          <div style="font-size:22px; font-weight:800"><%= settings && settings['company.currency_symbol'] ? `${settings['company.currency_symbol']} ${Number(car.price).toLocaleString()}` : Number(car.price).toLocaleString() %></div>
        </div>
        <div>
          <div class="muted">Mileage</div>
          <div style="font-size:18px"><%= car.mileage ? `${Number(car.mileage).toLocaleString()} km` : "—" %></div>
        </div>
      </div>
      <div class="grid" style="grid-template-columns: repeat(2, minmax(0,1fr)); gap:12px; margin-top:14px">
        <div class="card" style="background:rgba(255,255,255,.03)">
          <div class="muted">Transmission</div>
          <div><%= car.transmission || "—" %></div>
        </div>
        <div class="card" style="background:rgba(255,255,255,.03)">
          <div class="muted">Fuel</div>
          <div><%= car.fuel || "—" %></div>
        </div>
        <div class="card" style="background:rgba(255,255,255,.03)">
          <div class="muted">Color</div>
          <div><%= car.color || "—" %></div>
        </div>
        <div class="card" style="background:rgba(255,255,255,.03)">
          <div class="muted">Status</div>
          <div><%= car.status %></div>
        </div>
      </div>

      <% if (car.description) { %>
        <div style="margin-top:14px">
          <h3>Description</h3>
          <p class="muted" style="white-space:pre-wrap"><%= car.description %></p>
        </div>
      <% } %>
    </section>

    <aside class="form">
      <h3 style="margin:0 0 8px 0">Send message</h3>
      <p class="muted" style="margin:0 0 10px 0">Ask about this car and we’ll respond.</p>
      <form method="post" action="/contact">
        <input type="hidden" name="car_id" value="<%= car.id %>" />
        <label>Name</label>
        <input name="name" placeholder="Your name" required />
        <label>Email</label>
        <input name="email" placeholder="you@email.com" required />
        <label>Phone (optional)</label>
        <input name="phone" placeholder="Phone number" />
        <label>Message</label>
        <textarea name="message" required>Hello, I'm interested in "<%= car.title %>". Is it still available?</textarea>
        <div class="row" style="margin-top:12px">
          <button class="btn primary" type="submit">Send</button>
          <a class="btn" href="/cars">Back</a>
        </div>
      </form>
    </aside>
  </div>
</main>

<%- include("../partials/footer") %>

